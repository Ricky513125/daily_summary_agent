# DeepSeek API配置（V2使用）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 阿里千问API配置（V3使用）
DASHSCOPE_API_KEY=""
QWEN_MODEL=qwen-plus

# 向量数据库配置
VECTOR_DB_PATH=./data/vector_db

# 爬虫配置
WECHAT_ACCOUNTS=account1,account2,account3
ARCHIVE_URLS=https://example.com/archive1,https://example.com/archive2

# arXiv配置
ENABLE_ARXIV=true
ARXIV_CATEGORIES=cs.AI,cs.CV,cs.LG,cs.CL
ARXIV_MAX_RESULTS_PER_KEYWORD=10

# 日期过滤: yesterday(昨天), today(今天), 或数字(过去N天)
# 例如: yesterday, today, 1, 3, 7, 30
ARXIV_DATE_FILTER=yesterday

ARXIV_DOWNLOAD_PDF=true

# 内容过滤关键词
KEYWORDS=大模型,AI,人工智能,计算机视觉,深度学习,机器学习,LLM,GPT,transformer,后训练,强化学习,多模态,多模态大模型

# V3专属配置：查看N天前的文章
# 推荐：每周二至周六10:00运行，ARXIV_DAYS_AGO=1（抓取前一天的论文）
# 例如：周二10:00运行，ARXIV_DAYS_AGO=1，则查看周一的文章
ARXIV_DAYS_AGO=1

# V3 批量总结：跨关键词去重后，每N篇论文调用一次LLM
V3_BATCH_SIZE=20

# 去重配置（避免跨关键词/跨天重复分析同一篇论文）
# 默认启用：会把已处理论文记录写入 output/.cache/processed_papers.json（便于定时任务跨天持久化）
DEDUP_ENABLED=true
DEDUP_CACHE_PATH=./output/.cache/processed_papers.json
# 只保留最近 N 天记录，避免缓存无限增长
DEDUP_RETENTION_DAYS=180

# 邮件配置（V3定时任务使用）
EMAIL_ENABLED=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password
RECEIVER_EMAILS=receiver1@example.com,receiver2@example.com

# 注意：
# - V2 使用 main_v2.py，DeepSeek API
# - V3 使用 main_v3.py，阿里千问API，按日期组织文件夹，支持邮件发送

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log

# RAG配置
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=10

# 爬虫配置
CRAWL_TIMEOUT=30
MAX_ARTICLES_PER_SOURCE=50
