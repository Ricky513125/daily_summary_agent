# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 向量数据库配置
VECTOR_DB_PATH=./data/vector_db

# 爬虫配置
WECHAT_ACCOUNTS=account1,account2,account3
ARCHIVE_URLS=https://example.com/archive1,https://example.com/archive2

# arXiv配置
ENABLE_ARXIV=true
ARXIV_CATEGORIES=cs.AI,cs.CV,cs.LG,cs.CL
ARXIV_MAX_RESULTS_PER_KEYWORD=10

# 日期过滤: yesterday(昨天), today(今天), 或数字(过去N天)
# 例如: yesterday, today, 1, 3, 7, 30
ARXIV_DATE_FILTER=yesterday

ARXIV_DOWNLOAD_PDF=true

# 内容过滤关键词
KEYWORDS=大模型,AI,人工智能,计算机视觉,深度学习,机器学习,LLM,GPT,transformer,后训练,强化学习,多模态,多模态大模型

# 注意：使用 main_v2.py 时会按关键词分别处理
# 每个关键词会获取 ARXIV_MAX_RESULTS_PER_KEYWORD 篇论文
# 并生成单独的总结文件

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log

# RAG配置
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=10

# 爬虫配置
CRAWL_TIMEOUT=30
MAX_ARTICLES_PER_SOURCE=50
